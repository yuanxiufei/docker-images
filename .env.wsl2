# WSL2 环境变量 — 复制为 .env 放在 docker-images 目录下
# 注意：需要根据实际情况确认 D: 盘在 WSL2 中的挂载路径（/mnt/d/ 或 /mnt/软件/ 等）
SHARED_DATA=/mnt/d/app/Docker/SharedData
MODELS_DIR=/mnt/d/app/LLM/models
PLATFORM_DIR=/mnt/d/code/ai-fullstack-platform
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=studio
CELERY_POOL=solo
